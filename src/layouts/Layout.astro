---
import SeoHead from "../components/SeoHead.astro";
import CursorParticles from "../components/CursorParticles.astro";
import type { Lang } from "../i18n/index";
import "../styles/global.css";

export interface Props {
  lang: Lang;
  page: "home" | "about-me" | "uxui" | "frontend" | "visualArtist" | "projects" | "contact" | "terms" | "privacy" | "error";
  pathname: string;
  title?: string;
  description?: string;
}

const { lang, page, pathname, title, description } = Astro.props;
---

<!doctype html>
<html lang={lang === "en" ? "en" : "es"}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<link rel="icon" type="image/png" href="/Public/Icons/favicon.png" />
		

		<SeoHead lang={lang} page={page} pathname={pathname} title={title} description={description} />

		<script type="text/javascript" defer>
			(function (c, l, a, r, i, t, y) {
				c[a] =
					c[a] ||
					function () {
						(c[a].q = c[a].q || []).push(arguments);
					};
				t = l.createElement(r);
				t.async = 1;
				t.src = "https://www.clarity.ms/tag/" + i;
				y = l.getElementsByTagName(r)[0];
				y.parentNode.insertBefore(t, y);
			})(window, document, "clarity", "script", "tfbwgxewkn");
		</script>
	</head>
	<body>
		<CursorParticles />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0 auto;
		width: 100%;
		height: 100%;
		box-sizing: border-box;
		overflow-x: hidden;
		font-family: var(--albert);
		color: var(--text-white);
		
		
	}
</style>
