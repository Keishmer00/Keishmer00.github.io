---
import type { Lang } from "../i18n/index";
import { useTranslations } from "../i18n/index";
import LanguageSwitcher from "./LanguageSwitcher.astro";

export interface Props {
  lang: Lang;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const { t } = useTranslations(lang);

const localizedPath = (path: string) => {
  if (lang === "en") return path;
  return `/es${path}`;
};
---

<nav class="fixed flex w-full justify-between px-4 md:px-8 py-4 items-center z-10">
  <a
    href={localizedPath("/")}
    class="text-white hover:text-primary font-mono text-xl no-underline"
    aria-label={t("site.title")}
  >
    {t("nav.logo")}
  </a>

  <div class="flex items-center gap-3">
    <LanguageSwitcher lang={lang} pathname={pathname} />

    <button
      class="flex flex-col gap-2 w-auto h-auto z-50 relative group cursor-pointer"
      id="openMenu"
      aria-label={t("nav.menu")}
    >
      <div
        id="line1"
        class="w-6 h-0.5 bg-white transition-all duration-300 group-hover:bg-primary origin-center"
      >
      </div>
      <div
        id="line2"
        class="w-6 h-0.5 bg-white transition-all duration-300 group-hover:bg-primary origin-center"
      >
      </div>
    </button>
  </div>

  <div
    id="menuOverlay"
    class="fixed inset-0 lg:left-290 bg-black/95 lg:border-l lg:border-gray-400 backdrop-blur-md transition-opacity duration-300 opacity-0 pointer-events-none z-40 flex items-center justify-center"
  >
    <div
      class="flex flex-col items-start justify-start py-24 w-full h-full relative"
    >
      <div
        class="flex flex-col md:flex-row gap-12 items-start justify-start w-full max-w-4xl px-4 text-white"
      >
        <ul
          class="flex flex-col gap-6 text-2xl font-mono uppercase px-8 items-start w-full"
        >
          <p class="text-gray-300 text-sm uppercase tracking-widest mb-2">
            {t("nav.menu")}
          </p>
          <li>
            <a
              href={localizedPath("/about-me/")}
              class="flex items-center gap-4 hover:text-primary transition-colors group"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="24px"
                viewBox="0 -960 960 960"
                width="24px"
                fill="currentColor"
                class="group-hover:fill-primary transition-colors"
                ><path
                  d="M480-480q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 66-47 113t-113 47ZM160-160v-112q0-34 17.5-62.5T224-378q62-31 126-46.5T480-440q66 0 130 15.5T736-378q29 15 46.5 43.5T800-272v112H160Zm80-80h480v-32q0-11-5.5-20T700-306q-54-27-109-40.5T480-360q-56 0-111 13.5T260-306q-9 5-14.5 14t-5.5 20v32Zm240-320q33 0 56.5-23.5T560-640q0-33-23.5-56.5T480-720q-33 0-56.5 23.5T400-640q0 33 23.5 56.5T480-560Zm0-80Zm0 400Z"
                ></path></svg
              >
              {t("aboutMe.title")}
            </a>
          </li>
          <li>
            <a
              href={localizedPath("/projects/")}
              class="flex items-center gap-4 hover:text-primary transition-colors group"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="24px"
                viewBox="0 -960 960 960"
                width="24px"
                fill="currentColor"
                class="group-hover:fill-primary transition-colors"
                ><path
                  d="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h240l80 80h320q33 0 56.5 23.5T880-640v400q0 33-23.5 56.5T800-160H160Zm0-80h640v-400H447l-80-80H160v480Zm0 0v-480 480Z"
                ></path></svg
              >
              {t("nav.projects")}
            </a>
          </li>
          <li>
            <a
              href={localizedPath("/ux-ui-design/")}
              class="flex items-center gap-4 hover:text-primary transition-colors group"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="24px"
                viewBox="0 -960 960 960"
                width="24px"
                fill="currentColor"
                class="group-hover:fill-primary transition-colors"
                ><path
                  d="M200-80q-50 0-85-35t-35-85q0-39 22.5-69.5T160-313v-334q-35-13-57.5-43.5T80-760q0-50 35-85t85-35q39 0 69.5 22.5T313-800h334q12-35 42.5-57.5T760-880q50 0 85 35t35 85q0 40-22.5 70.5T800-647v334q35 13 57.5 43.5T880-200q0 50-35 85t-85 35q-39 0-69.5-22.5T647-160H313q-13 35-43.5 57.5T200-80Zm0-640q17 0 28.5-11.5T240-760q0-17-11.5-28.5T200-800q-17 0-28.5 11.5T160-760q0 17 11.5 28.5T200-720Zm560 0q17 0 28.5-11.5T800-760q0-17-11.5-28.5T760-800q-17 0-28.5 11.5T720-760q0 17 11.5 28.5T760-720ZM313-240h334q9-26 28-45t45-28v-334q-26-9-45-28t-28-45H313q-9 26-28 45t-45 28v334q26 9 45 28t28 45Zm447 80q17 0 28.5-11.5T800-200q0-17-11.5-28.5T760-240q-17 0-28.5 11.5T720-200q0 17 11.5 28.5T760-160Zm-560 0q17 0 28.5-11.5T240-200q0-17-11.5-28.5T200-240q-17 0-28.5 11.5T160-200q0 17 11.5 28.5T200-160Zm0-600Zm560 0Zm0 560Zm-560 0Z"
                ></path></svg
              >
              {t("nav.uxuiDesigner")}
            </a>
          </li>
          <li>
            <a
              href={localizedPath("/frontend-dev/")}
              class="flex items-center gap-4 hover:text-primary transition-colors group"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="24px"
                viewBox="0 -960 960 960"
                width="24px"
                fill="currentColor"
                class="group-hover:fill-primary transition-colors"
                ><path
                  d="M200-120q-33 0-56.5-23.5T120-200v-500q0-14 4.5-26.5T138-750l56-68q9-11 20.5-16.5T240-840h480q14 0 25.5 5.5T766-818l56 68q9 11 13.5 23.5T840-700v500q0 33-23.5 56.5T760-120H200Zm16-600h528l-34-40H250l-34 40Zm-16 520h560v-440H200v440Zm382-78 142-142-142-142-58 58 84 84-84 84 58 58Zm-202 0 58-58-84-84 84-84-58-58-142 142 142 142Zm-180 78v-440 440Z"
                ></path></svg
              >
              {t("nav.frontendDev")}
            </a>
          </li>
          <li>
            <a
              href={localizedPath("/visual-artist/")}
              class="flex items-center gap-4 hover:text-primary transition-colors group"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="24px"
                viewBox="0 -960 960 960"
                width="24px"
                fill="currentColor"
                class="group-hover:fill-primary transition-colors"
                ><path
                  d="M603-160h56v-83l102-24q21-5 43.5-11.5T827-299q0-8-8-14.5T792-326q-38-11-58-34t-18-49q2-21 19.5-37.5T785-474q28-10 41.5-22.5T840-526q0-20-17-30.5t-37-3.5q-6 2-12.5 3t-12.5 1q-26 0-43.5-20T700-625q0-26 13.5-47.5T727-720q0-17-14.5-28.5T677-760q-29 0-40.5 12.5T625-700q0 17 1.5 33t1.5 33q0 45-16 66t-50 21q-11 0-23-3t-23-3q-6 0-9.5 2.5T503-543q0 10 12 20t23 19q26 23 38 44t12 42q0 27-19.5 46T521-353q-11 0-21-2t-21-3q-28-2-43 5t-15 21q0 14 13 23t38 13l131 21v115Zm-450 40-73-33 200-440 73 33-200 440Zm370 40v-128l-57-8q-55-8-89.5-39.5T342-329q0-48 39.5-80.5T476-439q5 0 8.5.5t7.5 1.5q-8-8-15-14.5T464-465q-20-22-29-40.5t-9-37.5q0-38 21.5-62.5T504-630q7 0 19 .5t26 2.5q2-20 0-41t-2-41q0-63 34-97t97-34q56 0 93.5 32t36.5 78q0 23-8 45t-18 43q5-1 10.5-1.5t10.5-.5q48 0 82.5 34.5T920-525q0 43-30.5 77.5T818-402q7 2 13 4t12 5q29 14 47 39.5t18 55.5q0 38-33.5 66.5T779-188l-40 10v98H523ZM138-537q-29-29-43.5-65.5T80-679q0-84 58-142.5T280-880q40 0 76.5 15t65.5 44l-56 56q-17-17-39.5-26t-46.5-9q-50 0-85 35t-35 85q0 24 9 46.5t26 39.5l-57 57Zm493 128Z"
                ></path></svg
              >
              {t("nav.visualArtist")}
            </a>
          </li>
          <li>
            <a
              href={localizedPath("/contact/")}
              class="flex items-center gap-4 hover:text-primary transition-colors group"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="24px"
                viewBox="0 -960 960 960"
                width="24px"
                fill="currentColor"
                class="group-hover:fill-primary transition-colors"
                ><path
                  d="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm320-280L160-640v400h640v-400L480-440Zm0-80 320-200H160l320 200ZM160-640v-80 480-400Z"
                ></path></svg
              >
              {t("nav.contact")}
            </a>
          </li>
        </ul>
      </div>
      <div class="flex flex-col gap-4 p-12 justify-center lg:justify-start">
        <span class="font-mono uppercase text-gray-300">Social</span>
        <div class="flex gap-4">
        <a
          class="font-mono uppercase text-white hover:text-primary transition-colors"
          href="https://www.linkedin.com/in/keishmer-p%C3%A9rez-torres/"
          >LinkedIn</a
        >
        <a
          class="font-mono uppercase text-white hover:text-primary transition-colors"
          href="https://github.com/Keishmer00">GitHub</a
        >
        <a
          class="font-mono uppercase text-white hover:text-primary transition-colors"
          href="https://www.instagram.com/keishmer00/">Instagram</a
        >
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const openMenuBtn = document.getElementById("openMenu");
    const menuOverlay = document.getElementById("menuOverlay");
    const line1 = document.getElementById("line1");
    const line2 = document.getElementById("line2");
    let isMenuOpen = false;

    if (openMenuBtn && menuOverlay && line1 && line2) {
      openMenuBtn.addEventListener("click", () => {
        isMenuOpen = !isMenuOpen;

        if (isMenuOpen) {
          menuOverlay.classList.remove("opacity-0", "pointer-events-none");
          menuOverlay.classList.add("opacity-100", "pointer-events-auto");
          line1.classList.add("translate-y-[5px]", "rotate-45");
          line2.classList.add("-translate-y-[5px]", "-rotate-45");
        } else {
          menuOverlay.classList.add("opacity-0", "pointer-events-none");
          menuOverlay.classList.remove("opacity-100", "pointer-events-auto");
          line1.classList.remove("translate-y-[5px]", "rotate-45");
          line2.classList.remove("-translate-y-[5px]", "-rotate-45");
        }
      });
    }
  });
</script>
