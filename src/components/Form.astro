---
import type { Lang } from "../i18n/index";
import { useTranslations } from "../i18n/index";


export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { t } = useTranslations(lang);


---

<section
    id="contact"
    class="flex bg-black items-center justify-center w-full bg-brand-primary p-4 md:p-14 lg:p-16"
>
    <div
        id="contact-form-card"
        class="flex flex-col items-center justify-center w-full border border-gray-300 shadow-2xl shadow-white/30 px-6 py-10 bg-linear-to-br from-white/5 via-black to-white/5 md:px-10 md:py-12 lg:px-14 lg:py-16"
    >
        <header class="w-full flex flex-col items-center justify-center text-center mb-10 md:mb-12 lg:mb-14">
            <h6
                class="text-2xl md:text-3xl font-unbounded lg:text-4xl font-regular text-white leading-tight tracking-tight uppercase"
            >
                {t("form.title")}
            </h6>
            <p
                class="mt-3 md:mt-4 text-sm md:text-base font-mono text-gray-300 font-light leading-relaxed max-w-2xl text-center"
            >
            {t("form.description")}
            </p>
        </header>

        <div
            class="flex flex-col lg:flex-row items-center lg:items-stretch gap-10 lg:gap-12 xl:gap-16 lg:px-32"
        >
            <div class="w-full lg:flex-1 lg:max-w-xl">
                <form
                    id="users-form"
                    class="w-full lg:w-fit flex flex-col gap-2"
                >
                    <div class="flex flex-col gap-1 border-b border-black-700/25">
                        <label
                            for="legal-name"
                            class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-black-700"
                            >{t("form.name")}</label
                        >
                        <input
                            type="text"
                            name="legal-name"
                            id="legal-name"
                            autocomplete="name"
                            required
                            class="bg-transparent text-sm md:text-base text-black-700 outline-none placeholder:text-black-700/40 w-full"
                        />
                    </div>

                    <div class="flex flex-col gap-1 border-b border-black-700/25">
                        <label
                            for="client-email"
                            class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-black-700"
                            >{t("form.email")}</label
                        >
                        <input
                            type="email"
                            name="client-email"
                            id="client-email"
                            autocomplete="email"
                            required
                            class="bg-transparent text-sm md:text-base text-black-700 outline-none placeholder:text-black-700/40 w-full"
                        />
                    </div>

                    <div class="flex flex-col gap-1 border-b border-black-700/25">
                        <label
                            for="phone-number"
                            class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-black-700"
                            >{t("form.phone")}</label
                        >
                        <input
                            type="tel"
                            name="phone-number"
                            id="phone-number"
                            autocomplete="tel"
                            required
                            class="bg-transparent text-sm md:text-base text-black-700 outline-none placeholder:text-black-700/40 w-full"
                        />
                    </div>
                     <div class="flex flex-col gap-1 border-b border-black-700/25">
                        <label
                            for="text"
                            class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-black-700"
                            >{t("form.text")}</label
                        >
                        <input
                            type="text"
                            name="text"
                            id="text"
                            autocomplete="tel"
                            required
                            class="bg-transparent text-sm md:text-base text-black-700 outline-none placeholder:text-black-700/40 w-full"
                        />
                    </div>

                    <div id="form-status" class="text-sm font-medium hidden"></div>

                    <div class="flex flex-col gap-4 pt-12">
                        <button
                            type="submit"
                            id="submit-btn"
                            class="flex items-center justify-between gap-3 bg-white text-black font-grafton text-sm pl-4 pr-2 py-2 md:py-4 md:pl-6 md:pr-4 lg:py-2 lg:pl-4 lg:pr-2  hover:bg-primary transition-colors duration-300 w-full"
                        >
                            <span id="submit-text" class="text-xs md:text-base">{t("form.submit")}</span>
                            <span
                                class="w-8 h-8 rounded-full bg-brand-tertiary flex items-center justify-center shrink-0"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    height="20px"
                                    viewBox="0 -960 960 960"
                                    width="20px"
                                    fill="#121314"
                                    aria-hidden="true"
                                >
                                    <path
                                        d="m226-559 78 33q14-28 29-54t33-52l-56-11-84 84Zm142 83 114 113q42-16 90-49t90-75q70-70 109.5-155.5T806-800q-72-5-158 34.5T492-656q-42 42-75 90t-49 90Zm155-121.5q0-33.5 23-56.5t57-23q34 0 57 23t23 56.5q0 33.5-23 56.5t-57 23q-34 0-57-23t-23-56.5ZM565-220l84-84-11-56q-26 18-52 32.5T532-299l33 79Zm313-653q19 121-23.5 235.5T708-419l20 99q4 20-2 39t-20 33L538-80l-84-197-171-171-197-84 167-168q14-14 33.5-20t39.5-2l99 20q104-104 218-147t235-24ZM157-321q35-35 85.5-35.5T328-322q35 35 34.5 85.5T327-151q-25 25-83.5 43T82-76q14-103 32-161.5t43-83.5Zm57 56q-10 10-20 36.5T180-175q27-4 53.5-13.5T270-208q12-12 13-29t-11-29q-12-12-29-11.5T214-265Z"
                                    ></path>
                                </svg>
                            </span>
                        </button>

                        <p class="text-[10px] text-black-700/50 leading-relaxed lg:text-left text-center max-w-sm md:max-w-full lg:max-w-sm">
                            This site is protected by reCAPTCHA and the Google
                            <a
                                href="https://policies.google.com/privacy"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-black-700 hover:underline font-medium"
                                >{t("form.privacy")}</a
                            >
                            and
                            <a
                                href="https://policies.google.com/terms"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-black-700 hover:underline font-medium"
                                >{t("form.terms")}</a
                            >
                            {t("form.apply")}
                        </p>    
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script
    is:inline
    src={`https://www.google.com/recaptcha/api.js?render=${import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY}`}
></script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.querySelector(
            "#users-form",
        ) as HTMLFormElement;

        if (form) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault(); // Evitamos recarga de página

                const submitBtn = form.querySelector(
                    'button[type="submit"]',
                ) as HTMLButtonElement;
                const originalBtnText = submitBtn.innerHTML;

                // Estado de carga (opcional pero recomendado)
                submitBtn.disabled = true;
                submitBtn.innerHTML =
                    '<span class="text-sm font-medium">Verifying...</span>';

                try {
                    // @ts-ignore
                    grecaptcha.ready(function () {
                        // @ts-ignore - Reemplaza con tu clave pública
                        grecaptcha
                            .execute(
                                import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY,
                                { action: "submit" },
                            )
                            .then(async function (token: string) {
                                // Recopilar los datos del formulario
                                const formData = new FormData(form);
                                const formJSON = Object.fromEntries(
                                    formData.entries(),
                                );

                                // Preparamos el payload según lo requerido por la Edge Function
                                const payload = {
                                    legal_name: formJSON["legal-name"],
                                    client_email: formJSON["client-email"],
                                    phone_number: formJSON["phone-number"],
                                    text: formJSON["text"],
                                    recaptcha: token
                                };

                                // Enviar a nuestro backend de Astro
                                try {
                                    const ENDPOINT_URL = '/api/submit-clients';
                                    
                                    const response = await fetch(ENDPOINT_URL, {
                                        method: "POST",
                                        headers: {
                                            "Content-Type": "application/json",
                                        },
                                        body: JSON.stringify(payload),
                                    });

                                    const result = await response.json();

                                    if (response.ok && result.success) {
                                        // ÉXITO: El backend validó que es humano y procesó los datos
                                        submitBtn.innerHTML =
                                            '<span class="text-sm font-medium">Application Sent ✓</span>';
                                        submitBtn.classList.replace(
                                            "bg-black-700",
                                            "bg-green-600",
                                        );
                                        submitBtn.classList.replace(
                                            "text-white-500",
                                            "text-white",
                                        );
                                        form.reset();

                                        // Restaurar el botón después de 3 segundos
                                        setTimeout(() => {
                                            submitBtn.innerHTML =
                                                originalBtnText;
                                            submitBtn.classList.replace(
                                                "bg-green-600",
                                                "bg-black-700",
                                            );
                                            submitBtn.classList.replace(
                                                "text-white",
                                                "text-white-500",
                                            );
                                            submitBtn.disabled = false;
                                        }, 3000);
                                    } else {
                                        // ERROR: Probable bot o error de validación
                                        alert(
                                            "Security check failed or error occurred: " +
                                                (result.message ||
                                                    "Unknown error"),
                                        );
                                        submitBtn.innerHTML = originalBtnText;
                                        submitBtn.disabled = false;
                                    }
                                } catch (error) {
                                    console.error(
                                        "Error submitting form:",
                                        error,
                                    );
                                    alert(
                                        "Failed to connect to the server. Please try again.",
                                    );
                                    submitBtn.innerHTML = originalBtnText;
                                    submitBtn.disabled = false;
                                }
                            });
                    });
                } catch (error) {
                    console.error("reCAPTCHA failed to load:", error);
                    alert(
                        "reCAPTCHA failed to load. Please disable ad-blockers and try again.",
                    );
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                }
            });
        }
    });

    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const mm = gsap.matchMedia();

        mm.add("(min-width: 1px)", () => {
            gsap.from("#contact-form-card", {
                opacity: 0,
                scale: 0.98,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#contact",
                    start: "top 85%",
                    end: "top 30%",
                    scrub: 1,
                },
            });

            gsap.from("#contact h2, #contact header p", {
                opacity: 0,
                y: 30,
                stagger: 0.2,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#contact",
                    start: "top 80%",
                    end: "top 30%",
                    scrub: 1,
                },
            });

            gsap.from("#users-form > div", {
                opacity: 0,
                y: 20,
                stagger: 0.1,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: "#users-form",
                    start: "top 85%",
                    end: "top 30%",
                    scrub: 1,
                },
            });

            gsap.from("#contact img", {
                opacity: 0,
                x: 30,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#contact-form-card",
                    start: "top 85%",
                    end: "top 30%",
                    scrub: 1,
                },
            });
        });
    });
</script>