---
// Cursor Particle System - Trail on movement, idle orbit ring on desktop only
---

<canvas id="cursor-particles" class="fixed inset-0 pointer-events-none z-50 hidden lg:block"></canvas>

<script>
  // Desktop-only: mouse pointer + large screen
  const isDesktop = window.matchMedia('(min-width: 1024px) and (pointer: fine)').matches;
  if (!isDesktop) {
    // Do not initialize on mobile/tablet to save battery/CPU
    const canvas = document.getElementById('cursor-particles');
    if (canvas) canvas.remove();
    throw new Error('CursorParticles skipped: not desktop');
  }

  const canvasEl = document.getElementById('cursor-particles');
  if (!canvasEl) throw new Error('Canvas element not found');
  const canvas = canvasEl as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('Could not get 2D context');

  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  let mouseX = width / 2;
  let mouseY = height / 2;
  let targetX = width / 2;
  let targetY = height / 2;
  let lastMoveTime = Date.now();

  const particles: Particle[] = [];
  const particleColor = 'rgba(198, 210, 212, '; // #c6d2d4 - project white

  // Configuration
  const IDLE_THRESHOLD = 80; // ms without movement to enter idle mode
  const IDLE_COUNT = 20; // particles in the idle ring
  const IDLE_RADIUS = 25; // base orbit radius in px
  const IDLE_ORBIT_SPEED = 0.002; // radians per frame (slow)
  const MAX_TRAIL_PARTICLES = 60;

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    life: number;
    maxLife: number;
    alpha: number;
    mode: 'trail' | 'idle';
    angle: number;
    radius: number;
    speed: number;
  }

  class Particle {
    constructor(x: number, y: number, mode: 'trail' | 'idle' = 'trail', startAngle?: number) {
      this.x = x;
      this.y = y;
      this.mode = mode;
      this.size = Math.random() * 2 + 1;
      this.life = 0;
      this.angle = 0;
      this.radius = 0;
      this.speed = 0;

      if (mode === 'trail') {
        const angle = Math.random() * Math.PI * 2;
        const speed = Math.random() * 2 + 0.5;
        this.vx = Math.cos(angle) * speed;
        this.vy = Math.sin(angle) * speed;
        this.maxLife = Math.random() * 40 + 30;
        this.alpha = 1;
      } else {
        // Idle orbit
        this.angle = startAngle ?? Math.random() * Math.PI * 2;
        this.radius = IDLE_RADIUS + (Math.random() - 0.5) * 20;
        this.speed = IDLE_ORBIT_SPEED * (Math.random() > 0.5 ? 1 : -1);
        this.vx = 0;
        this.vy = 0;
        this.maxLife = Infinity;
        this.alpha = 0.8;
      }
    }

    update(targetX: number, targetY: number) {
      if (this.mode === 'idle') {
        // Orbit slowly around cursor
        this.angle += this.speed;
        const orbitX = targetX + Math.cos(this.angle) * this.radius;
        const orbitY = targetY + Math.sin(this.angle) * this.radius;

        // Smooth approach to orbit position
        this.x += (orbitX - this.x) * 0.08;
        this.y += (orbitY - this.y) * 0.08;

        this.life++;
        // Gentle alpha pulse
        this.alpha = 0.5 + Math.sin(this.life * 0.04) * 0.25;
      } else {
        // Trail physics
        this.x += this.vx;
        this.y += this.vy;
        this.vx *= 0.98;
        this.vy *= 0.98;
        this.life++;
        this.alpha = Math.max(0, 1 - this.life / this.maxLife);
      }
    }

    draw() {
      if (!ctx) return;
      ctx.strokeStyle = particleColor + this.alpha + ')';
      ctx.lineWidth = 1;
      ctx.strokeRect(this.x - this.size / 2, this.y - this.size / 2, this.size, this.size);
    }

    toTrail() {
      this.mode = 'trail';
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 3 + 0.8;
      this.vx = Math.cos(angle) * speed;
      this.vy = Math.sin(angle) * speed;
      this.maxLife = Math.random() * 40 + 30;
      this.life = 0;
      this.alpha = 1;
    }

    toIdle(startAngle: number) {
      this.mode = 'idle';
      this.angle = startAngle;
      this.radius = IDLE_RADIUS + (Math.random() - 0.5) * 20;
      this.speed = IDLE_ORBIT_SPEED * (Math.random() > 0.5 ? 1 : -1);
      this.vx = 0;
      this.vy = 0;
      this.maxLife = Infinity;
      this.alpha = 0.8;
    }
  }

  function createTrailParticle(x: number, y: number) {
    if (particles.filter(p => p.mode === 'trail').length < MAX_TRAIL_PARTICLES) {
      particles.push(new Particle(x, y, 'trail'));
    }
  }

  function connectParticles() {
    if (!ctx) return;
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const distance = Math.sqrt(dx * dx + dy * dy);

        if (distance < 80) {
          const alpha = (1 - distance / 80) * Math.min(particles[i].alpha, particles[j].alpha) * 0.3;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.strokeStyle = particleColor + alpha + ')';
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }
  }

  function animate() {
    ctx!.clearRect(0, 0, width, height);

    // Smooth cursor following
    mouseX += (targetX - mouseX) * 0.1;
    mouseY += (targetY - mouseY) * 0.1;

    const timeSinceLastMove = Date.now() - lastMoveTime;
    const isIdle = timeSinceLastMove > IDLE_THRESHOLD;

    if (isIdle) {
      // Maintain idle ring
      const idleParticles = particles.filter(p => p.mode === 'idle');
      if (idleParticles.length < IDLE_COUNT && Math.random() < 0.4) {
        const angle = (idleParticles.length / IDLE_COUNT) * Math.PI * 2;
        particles.push(new Particle(mouseX, mouseY, 'idle', angle));
      }

      // Convert surviving trail particles into idle orbiters
      const trailParticles = particles.filter(p => p.mode === 'trail');
      for (let i = 0; i < Math.min(2, trailParticles.length); i++) {
        const idx = particles.indexOf(trailParticles[i]);
        if (idx !== -1) {
          const angle = (idleParticles.length / IDLE_COUNT) * Math.PI * 2;
          particles[idx].toIdle(angle);
        }
      }
    } else {
      // Cursor is moving: spawn trail
      if (Math.random() < 0.7) {
        createTrailParticle(mouseX, mouseY);
      }

      // Burst idle ring particles into trail
      const idleParticles = particles.filter(p => p.mode === 'idle');
      for (let i = 0; i < Math.min(3, idleParticles.length); i++) {
        const idx = particles.indexOf(idleParticles[i]);
        if (idx !== -1) {
          particles[idx].toTrail();
        }
      }
    }

    // Update and draw particles
    for (let i = particles.length - 1; i >= 0; i--) {
      particles[i].update(mouseX, mouseY);
      particles[i].draw();

      // Remove dead trail particles
      if (particles[i].mode === 'trail' && particles[i].life >= particles[i].maxLife) {
        particles.splice(i, 1);
      }
    }

    // Cap idle particles
    const idleParticles = particles.filter(p => p.mode === 'idle');
    if (idleParticles.length > IDLE_COUNT) {
      // Remove oldest idle particles
      const toRemove = idleParticles.length - IDLE_COUNT;
      for (let i = 0; i < toRemove; i++) {
        const idx = particles.indexOf(idleParticles[i]);
        if (idx !== -1) particles.splice(idx, 1);
      }
    }

    connectParticles();
    requestAnimationFrame(animate);
  }

  // Mouse move handler (desktop only)
  document.addEventListener('mousemove', (e: MouseEvent) => {
    targetX = e.clientX;
    targetY = e.clientY;
    lastMoveTime = Date.now();
  });

  // Resize handler
  window.addEventListener('resize', () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  });

  // Start animation
  animate();
</script>
