---
// Cursor Particle System - Fluid, abstract white particles following cursor
---

<canvas id="cursor-particles" class="fixed inset-0 pointer-events-none z-50"></canvas>

<script>
  const canvasEl = document.getElementById('cursor-particles');
  if (!canvasEl) throw new Error('Canvas element not found');
  const canvas = canvasEl as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('Could not get 2D context');

  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  let mouseX = width / 2;
  let mouseY = height / 2;
  let targetX = width / 2;
  let targetY = height / 2;
  let isMoving = false;
  let lastMoveTime = Date.now();

  const particles: Particle[] = [];
  const maxParticles = 80;
  const particleColor = 'rgba(198, 210, 212, '; // #c6d2d4 - project white

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    life: number;
    maxLife: number;
    alpha: number;
  }

  class Particle {
    constructor(x: number, y: number) {
      this.x = x;
      this.y = y;
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 2 + 0.5;
      this.vx = Math.cos(angle) * speed;
      this.vy = Math.sin(angle) * speed;
      this.size = Math.random() * 3 + 1;
      this.life = 0;
      this.maxLife = Math.random() * 60 + 40;
      this.alpha = 1;
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;
      this.vx *= 0.98;
      this.vy *= 0.98;
      this.life++;
      this.alpha = 1 - (this.life / this.maxLife);
    }

    draw() {
      if (!ctx) return;
      ctx.strokeStyle = particleColor + this.alpha + ')';
      ctx.lineWidth = 1;
      ctx.strokeRect(this.x - this.size / 2, this.y - this.size / 2, this.size, this.size);
    }
  }

  function createParticles(x: number, y: number, count: number = 3) {
    for (let i = 0; i < count; i++) {
      if (particles.length < maxParticles) {
        particles.push(new Particle(x, y));
      }
    }
  }

  function connectParticles() {
    if (!ctx) return;
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const distance = Math.sqrt(dx * dx + dy * dy);

        if (distance < 80) {
          const alpha = (1 - distance / 80) * Math.min(particles[i].alpha, particles[j].alpha) * 0.3;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.strokeStyle = particleColor + alpha + ')';
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }
  }

  function animate() {
    ctx!.clearRect(0, 0, width, height);

    // Smooth cursor following
    mouseX += (targetX - mouseX) * 0.1;
    mouseY += (targetY - mouseY) * 0.1;

    // Check if cursor is moving
    const timeSinceLastMove = Date.now() - lastMoveTime;
    const isCursorMoving = timeSinceLastMove < 100;

    // Create particles at cursor position - fewer when idle
    const particleCount = isCursorMoving ? 2 : 0.3;
    if (Math.random() < particleCount) {
      createParticles(mouseX, mouseY, 1);
    }

    // Update and draw particles
    for (let i = particles.length - 1; i >= 0; i--) {
      particles[i].update();
      particles[i].draw();

      if (particles[i].life >= particles[i].maxLife) {
        particles.splice(i, 1);
      }
    }

    // Connect nearby particles
    connectParticles();

    requestAnimationFrame(animate);
  }

  // Mouse move handler
  document.addEventListener('mousemove', (e: MouseEvent) => {
    targetX = e.clientX;
    targetY = e.clientY;
    lastMoveTime = Date.now();
  });

  // Touch support
  document.addEventListener('touchmove', (e: TouchEvent) => {
    targetX = e.touches[0].clientX;
    targetY = e.touches[0].clientY;
    lastMoveTime = Date.now();
  });

  // Resize handler
  window.addEventListener('resize', () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  });

  // Start animation
  animate();
</script>
