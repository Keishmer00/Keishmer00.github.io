---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import type { Lang } from "../../i18n/index";
import { useTranslations } from "../../i18n/index";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "es" } },
  ];
}

const { lang = "en" } = Astro.params as { lang?: Lang };
const { t } = useTranslations(lang);
const pathname = lang === "en" ? "/visual-artist/" : "/es/visual-artist/";
---

<Layout lang={lang} page="visualArtist" pathname={pathname}>
  <Navbar lang={lang} pathname={pathname} />
  <main class="bg-black flex flex-col items-center justify-center min-h-screen px-4 pt-24">
    <h1 class="text-5xl font-unbounded text-white text-center">{t("nav.visualArtist")}</h1>
    <p class="text-gray-400 text-center mt-4 max-w-xl">
      {t("subpages.visualDescription")}
    </p>
  </main>
</Layout>
