---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Breadcrumbs from "../../components/atoms/Breadcrumbs.astro";
import Footer from "../../components/Footer.astro";
import CTA from "../../components/CTA.astro";
import type { Lang } from "../../i18n/index";
import { useTranslations } from "../../i18n/index";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "es" } },
  ];
}

const { lang = "en" } = Astro.params as { lang?: Lang };
const { t } = useTranslations(lang);
const pathname = lang === "en" ? "/404" : "/es/404";

Astro.response.status = 404;
---

<Layout lang={lang} page="error" pathname={pathname}>
    <Navbar lang={lang} pathname={pathname} />
    <Breadcrumbs
        items={[
            { label: t("projects.breadcrumbHome"), href: "/" },
            { label: "404" }
        ]}
        absolute
        light
    />
    <main
        class="flex flex-col justify-center items-center text-center p-4 w-full min-h-screen"
    >
        <h1 class="text-8xl font-unbounded text-primary font-bold mb-4">404</h1>

        <p class="text-gray-400 text-lg mb-10 max-w-lg">
            {t("error.message")}
        </p>
        <CTA text={t("error.cta")} link="/" />
    </main>
    <Footer lang={lang} pathname={pathname} />
</Layout>
